# Copy this to .env.local and fill in values.
# .env.local is git-ignored and can be generated by: npm run db:setup <name>

# Supabase (public)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_HOSTNAME=your-project-ref.supabase.co

# Public-facing origin — used to build absolute URLs that get handed off to
# external systems (Stripe success_url, portal return_url, etc.). Required
# in production behind a TLS-terminating proxy (DO App Platform, Vercel),
# where request.nextUrl.origin returns the internal container address.
# Leave unset in local dev; the helper falls back to host headers.
# NEXT_PUBLIC_SITE_URL=https://yourdomain.com

# Supabase (private - never commit)
SUPABASE_SECRET_KEY=sb_secret_...
SUPABASE_DB_PASSWORD=...

# Stripe
# Restricted key (rk_test_... / rk_live_...) is used for all transactional API
# calls (checkout sessions list+create, billing portal sessions, customer
# list+create, subscription list, price reads). In Stripe's scope model Write
# implies Read, so the dashboard scopes are:
#   Checkout Sessions      Write
#   Billing Portal Sessions Write
#   Customers              Write
#   Subscriptions          Read
#   Prices                 Read
# Everything else: None (no refund/charge/payout/etc. capability if leaked).
# The full secret key (sk_...) is kept around for ad-hoc admin work but the
# app never reads it. Webhook secret is the signing secret from the endpoint.
STRIPE_PUBLIC_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_RESTRICTED_KEY=rk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID_ANNUAL=price_...
STRIPE_PRICE_ID_MONTHLY=price_...

# Axiom logging
# Get dataset + token: https://app.axiom.co/settings/api-tokens
# Leave unset in dev if you only want local console logs.
NEXT_PUBLIC_AXIOM_TOKEN=
NEXT_PUBLIC_AXIOM_DATASET=
NEXT_PUBLIC_AXIOM_LOG_LEVEL=debug

# One-time project provisioning credentials
# These are needed only when running `npm run db:setup`.
# Get access token: https://supabase.com/dashboard/account/tokens
# Get org ID:       https://supabase.com/dashboard/org/<slug>/general
# You can also store these in ~/.creds (same KEY=VALUE format)
# SUPABASE_ACCESS_TOKEN=sbp_...
# SUPABASE_ORG_ID=org_...
# SUPABASE_REGION=us-east-1
# SUPABASE_PLAN=pro
