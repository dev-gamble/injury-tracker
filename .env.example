# Copy this to .env.local and fill in values.
# .env.local is git-ignored and can be generated by: npm run db:setup <name>

# Supabase (public)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_HOSTNAME=your-project-ref.supabase.co

# Supabase (private - never commit)
SUPABASE_SECRET_KEY=sb_secret_...
SUPABASE_DB_PASSWORD=...

# Axiom logging
# Get dataset + token: https://app.axiom.co/settings/api-tokens
# Leave unset in dev if you only want local console logs.
NEXT_PUBLIC_AXIOM_TOKEN=
NEXT_PUBLIC_AXIOM_DATASET=
NEXT_PUBLIC_AXIOM_LOG_LEVEL=debug

# One-time project provisioning credentials
# These are needed only when running `npm run db:setup`.
# Get access token: https://supabase.com/dashboard/account/tokens
# Get org ID:       https://supabase.com/dashboard/org/<slug>/general
# You can also store these in ~/.creds (same KEY=VALUE format)
# SUPABASE_ACCESS_TOKEN=sbp_...
# SUPABASE_ORG_ID=org_...
# SUPABASE_REGION=us-east-1
# SUPABASE_PLAN=pro
