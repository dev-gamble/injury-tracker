# Docker / registry settings
IMAGE_NAME=myapp
DO_REGISTRY=registry.digitalocean.com/my-registry

# Build-time env vars (baked into the image)
# Supabase (public)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_HOSTNAME=your-project-ref.supabase.co

# Optional Axiom logging (browser + server)
# If unset, logs stay local/console.
# NEXT_PUBLIC_AXIOM_TOKEN=xaat-...
# NEXT_PUBLIC_AXIOM_DATASET=webapp-logs
# NEXT_PUBLIC_AXIOM_LOG_LEVEL=info

# Runtime secrets
# Set these in the DigitalOcean App Platform dashboard, not here.
# SUPABASE_SECRET_KEY=sb_secret_...
