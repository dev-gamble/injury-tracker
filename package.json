{
  "name": "injury-tracker",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "node -e \"require('fs').rmSync('.next/types',{ recursive: true, force: true })\" && next typegen && tsc --noEmit",
    "db:setup": "npx tsx scripts/setup-db.ts",
    "db:init": "npm install && npx tsx scripts/setup-db.ts",
    "db:dump": "npx supabase db dump --linked -f supabase/schema.sql",
    "db:push": "npx supabase db push",
    "db:reset": "npx supabase db reset"
  },
  "dependencies": {
    "@supabase/ssr": "^0.6.1",
    "@supabase/supabase-js": "^2.49.4",
    "dompurify": "^3.3.3",
    "lucide-react": "^0.539.0",
    "next": "^15.4.2",
    "next-axiom": "^1.10.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/dompurify": "^3.0.5",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.2.4",
    "eslint": "^9",
    "eslint-config-next": "^15.4.2",
    "supabase": "^2.75.5",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
